---
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout title="Letáky" description="Tisknutelné letáky pro šíření povědomí o samostudiu — připravujeme.">
  <section class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Letáky</h1>
    <p class="mt-3 text-muted leading-relaxed">
      Věříme, že i offline svět stojí za to oslovit. Připravujeme tisknutelné letáky ve formátu PDF, které si budeš
      moci stáhnout a šířit samostudium ve svém okolí.
    </p>

    <div class="mt-12 rounded-xl border border-border bg-surface p-10 text-center">
      <span class="mx-auto flex h-16 w-16 items-center justify-center rounded-xl bg-accent/10 text-accent">
        <Icon name="printer" size={32} />
      </span>
      <h2 class="mt-5 text-xl font-semibold">Zatím tu nic není</h2>
      <p class="mt-2 text-muted">Letáky ke stažení a tisku připravujeme.</p>
      <a
        href="/chci-pomoct"
        class="mt-6 inline-block rounded-lg bg-accent px-5 py-3 font-medium text-accent-contrast transition hover:opacity-90"
      >
        Chci pomoct s tvorbou
      </a>
    </div>
  </section>
</BaseLayout>

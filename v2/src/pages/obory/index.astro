---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import StatusBadge from "../../components/StatusBadge.astro";

const entries = (await getCollection("obory")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Obory" description="Rozcestníky k jednotlivým oborům — od úvodu po doporučené materiály.">
  <section class="mx-auto max-w-5xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Obory</h1>
    <p class="mt-3 text-muted">
      Rozcestníky k jednotlivým oborům — od úvodu po doporučené materiály.
    </p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        entries.map((entry) => (
          <a
            href={`/obory/${entry.id}`}
            class="rounded-xl border border-border bg-surface p-5 transition hover:border-accent"
          >
            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
              <Icon name={entry.data.icon as any} size={22} />
            </span>
            <h2 class="mt-3 font-semibold">{entry.data.title}</h2>
            <p class="mt-1 text-sm text-muted">{entry.data.summary}</p>
            <div class="mt-3">
              <StatusBadge status={entry.data.status} />
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Kontakt" description="Jak se spojit s projektem Samostuduj — Signal, Discord, Instagram a e-mail.">
  <section class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Kontakt</h1>

    <h2 class="text-xl font-semibold mt-12 mb-4">Upřednostňované (bezpečnější / soukromější)</h2>
    <ul class="space-y-4">
      <li class="flex flex-col gap-0.5">
        <span class="font-medium text-fg">Signal — Nikita</span>
        <span class="text-muted">nktrjsk.69</span>
      </li>
      <li class="flex flex-col gap-0.5">
        <span class="font-medium text-fg">Signal skupina Samostuduj</span>
        <a
          href="https://signal.group/#CjQKIMNaz2xaI8KdNXR77-6TMccTjokfUDfbIioiJeI1vnZjEhDQ0LT3SFgnzJ72qtbT8sjq"
          class="text-accent hover:underline"
          rel="noopener"
          target="_blank"
        >
          Připojit se ke skupině →
        </a>
      </li>
    </ul>

    <h2 class="text-xl font-semibold mt-12 mb-4">Méně soukromé</h2>
    <ul class="space-y-4">
      <li class="flex flex-col gap-0.5">
        <span class="font-medium text-fg">Discord</span>
        <a
          href="https://discord.gg/bjYbFV9pPv"
          class="text-accent hover:underline"
          rel="noopener"
          target="_blank"
        >
          discord.gg/bjYbFV9pPv
        </a>
      </li>
      <li class="flex flex-col gap-0.5">
        <span class="font-medium text-fg">Instagram</span>
        <span class="text-muted">@nktrjsk</span>
      </li>
      <li class="flex flex-col gap-0.5">
        <span class="font-medium text-fg">E-mail</span>
        <a
          href="mailto:personal@nktrjsk.cz"
          class="text-accent hover:underline"
        >
          personal@nktrjsk.cz
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>

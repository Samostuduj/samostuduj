---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AnnouncementCard from "../../components/AnnouncementCard.astro";
import { getLiveAktuality } from "../../lib/aktuality";

const items = await getLiveAktuality();
---

<BaseLayout
  title="Aktuality"
  description="Novinky ze Samostuduj — nový obsah, výzvy k pomoci a další oznámení."
>
  <section class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Aktuality</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Co je nového — nový obsah, s čím hledáme pomoc a další oznámení.
    </p>

    {
      items.length > 0 ? (
        <div class="mt-10 grid gap-4">
          {items.map((entry) => (
            <AnnouncementCard entry={entry} />
          ))}
        </div>
      ) : (
        <p class="mt-10 text-muted">Zatím tu nic není. Brzy!</p>
      )
    }
  </section>
</BaseLayout>

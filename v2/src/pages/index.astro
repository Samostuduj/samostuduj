---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const audience = [
  { icon: "graduation-cap", title: "Zklamaní studenti", text: "Školní systém tě zklamal? Vezmi vzdělávání do vlastních rukou — uč se to, co tě opravdu zajímá, vlastním tempem." },
  { icon: "clock", title: "Zaneprázdnění", text: "Rodiče i vytížení pracující. Přehledné materiály, aby bylo studium co nejjednodušší — bez zbytečného tlaku." },
  { icon: "sparkles", title: "Polyhistorové", text: "Od fyziky po filozofii. Nemusíš čekat na školní osnovy — poskládej si vlastní plán, přesně jak ti dává smysl." },
  { icon: "compass", title: "Nenašel jsem se", text: "To je v pořádku. Žádné škatulky — jen prostor učit se tak, jak ti to vyhovuje." },
] as const;

const dateFmt = new Intl.DateTimeFormat("cs-CZ", { dateStyle: "long" });
---

<BaseLayout>
  <!-- Hero -->
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-12 md:px-6 md:pt-24">
    <p class="mb-4 inline-block rounded-full border border-accent px-3 py-1 text-xs font-medium text-accent">
      Zdarma · svobodné licence · vlastním tempem
    </p>
    <h1 class="max-w-3xl text-4xl font-bold leading-tight tracking-tight md:text-5xl">
      Učení není pro každého stejné.<br />
      <span class="text-accent">Uč se po svém.</span>
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-muted">
      Ze školy sis odnesl(a) spíš pachuť než motivaci? Možná to jen chce jiný
      přístup. <em>Samostuduj</em> je projekt pro lidi, kteří se chtějí vzdělávat
      stejně důkladně jako na vysoké škole — ale po svém.
    </p>
    <div class="mt-8 flex flex-wrap gap-3">
      <a
        href="/plany"
        class="rounded-lg bg-accent px-5 py-3 font-medium text-accent-contrast transition hover:opacity-90"
      >
        Prozkoumat studijní plány
      </a>
      <a
        href="/blog"
        class="rounded-lg border border-border px-5 py-3 font-medium transition hover:text-accent"
      >
        Číst blog
      </a>
    </div>
  </section>

  <!-- Pro koho -->
  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6">
    <h2 class="text-2xl font-bold">Pro koho samostudium je?</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2">
      {
        audience.map((a) => (
          <div class="rounded-xl border border-border bg-surface p-5">
            <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent/10 text-accent">
              <Icon name={a.icon} size={22} />
            </span>
            <h3 class="mt-3 font-semibold">{a.title}</h3>
            <p class="mt-1 text-sm text-muted">{a.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Nejnovější z blogu -->
  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-2xl font-bold">Nejnovější z blogu</h2>
      <a href="/blog" class="text-sm text-accent hover:underline">Všechny články →</a>
    </div>
    <ul class="mt-6 grid gap-4 md:grid-cols-3">
      {
        posts.map((post) => (
          <li class="rounded-xl border border-border bg-surface p-5 transition hover:border-accent">
            <a href={`/blog/${post.id}`} class="block">
              <time class="text-xs text-muted" datetime={post.data.date.toISOString()}>
                {dateFmt.format(post.data.date)}
              </time>
              <h3 class="mt-1 font-semibold leading-snug">{post.data.title}</h3>
              {post.data.summary && (
                <p class="mt-2 text-sm text-muted">{post.data.summary}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

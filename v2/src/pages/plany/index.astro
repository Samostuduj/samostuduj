---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBadge from "../../components/StatusBadge.astro";

const entries = await getCollection("plany", ({ data }) => !data.draft);

// Group by obor, fallback to "Ostatní"
const groups = new Map<string, typeof entries>();
for (const entry of entries) {
  const key = entry.data.obor ?? "Ostatní";
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(entry);
}

// Sort each group by order ascending
for (const [, list] of groups) {
  list.sort((a, b) => a.data.order - b.data.order);
}

const levelLabel: Record<string, string> = {
  "úvod": "Úvod",
  "bakalář": "Bakalář",
  "magistr": "Magistr",
};
---

<BaseLayout title="Studijní plány" description="Osnovy a doporučené cesty pro samostatné studium různých oborů vlastním tempem.">
  <section class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Studijní plány</h1>
    <p class="mt-3 text-muted">
      Přehledné osnovy, které ti ukáží cestu oborem — studuj vlastním tempem, bez školy.
    </p>

    {
      [...groups.entries()].map(([obor, plans]) => (
        <section>
          <h2 class="mt-12 text-xl font-semibold">{obor}</h2>
          <ul class="mt-4 space-y-3">
            {plans.map((entry) => (
              <li>
                <a
                  href={`/plany/${entry.id}`}
                  class="block rounded-xl border border-border bg-surface p-5 transition hover:border-accent"
                >
                  <div class="flex items-start justify-between gap-4">
                    <div class="min-w-0">
                      <span class="font-semibold">{entry.data.title}</span>
                      {entry.data.level && (
                        <span class="ml-2 text-sm text-muted">
                          {levelLabel[entry.data.level]}
                        </span>
                      )}
                      {entry.data.summary && (
                        <p class="mt-1 text-sm text-muted">{entry.data.summary}</p>
                      )}
                    </div>
                    <StatusBadge status={entry.data.status} />
                  </div>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))
    }
  </section>
</BaseLayout>

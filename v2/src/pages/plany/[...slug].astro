---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBadge from "../../components/StatusBadge.astro";

export async function getStaticPaths() {
  const entries = await getCollection("plany", ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const levelLabel: Record<string, string> = {
  "úvod": "Úvod",
  "bakalář": "Bakalář",
  "magistr": "Magistr",
};

const meta = [entry.data.obor, entry.data.level ? levelLabel[entry.data.level] : undefined]
  .filter(Boolean)
  .join(" · ");
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <a href="/plany" class="text-sm text-accent hover:underline">← Zpět na plány</a>
    <header class="mt-6">
      <h1 class="text-3xl font-bold leading-tight tracking-tight md:text-4xl">
        {entry.data.title}
      </h1>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        {meta && <p class="text-sm text-muted">{meta}</p>}
        <StatusBadge status={entry.data.status} />
      </div>
    </header>
    <div class="prose mt-8">
      <Content />
    </div>
  </article>
</BaseLayout>

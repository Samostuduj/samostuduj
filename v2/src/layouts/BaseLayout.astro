---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Samostuduj",
  description = "Vzdělávej se důkladně jako na vysoké škole — ale po svém. Materiály, studijní plány a komunita pro samouky.",
} = Astro.props;

const fullTitle = title === "Samostuduj" ? title : `${title} — Samostuduj`;
---

<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <!-- Set theme before paint to avoid a flash of the wrong mode -->
    <script is:inline>
      const t = localStorage.getItem("samostuduj-theme");
      if (t === "dark" || t === "light")
        document.documentElement.classList.add(t);
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
// Primary navigation — implements the grouped IA from issue #7.
// Dropdowns use <details> so they work without JS.
import Icon from "./Icon.astro";

const nav = [
  {
    label: "Obory",
    href: "/obory",
    children: [
      { label: "Psychologie", href: "/obory/psychologie" },
      { label: "IT", href: "/obory/it" },
      { label: "Ekonomie", href: "/obory/ekonomie" },
      { label: "Právo", href: "/obory/pravo" },
      { label: "Sociologie", href: "/obory/sociologie" },
      { label: "Matematika", href: "/obory/matematika" },
      { label: "Filozofie", href: "/obory/filozofie" },
    ],
  },
  { label: "Studijní plány", href: "/plany" },
  { label: "Blog", href: "/blog" },
  { label: "Letáky", href: "/letaky" },
  {
    label: "O Samostuduj",
    children: [
      { label: "Chci pomoct", href: "/chci-pomoct" },
      { label: "FAQ", href: "/faq" },
      { label: "O projektu", href: "/o-projektu" },
      { label: "Kontakt", href: "/kontakt" },
    ],
  },
];

// The mobile menu uses its own prioritized IA (start-here pair, then fields,
// then secondary/tertiary) rather than mirroring the flat desktop nav.
const oboryFields = nav.find((n) => n.label === "Obory")?.children ?? [];

// Active-page state. A link is active on an exact match or when the current
// path sits under it (e.g. /blog is active on /blog/some-post).
const path = (Astro.url.pathname.replace(/\/+$/, "") || "/").toLowerCase();
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");
const isGroupActive = (children?: { href: string }[]) =>
  (children ?? []).some((c) => isActive(c.href));
---

<header
  class="sticky top-0 z-50 border-b border-border bg-bg/85 backdrop-blur-sm"
>
  <div
    class="mx-auto flex max-w-5xl items-center gap-4 px-4 py-3 md:px-6"
  >
    <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Samostuduj — domů">
      <img
        src="/img/samostuduj_icon_black.svg"
        alt=""
        width="32"
        height="32"
        class="h-8 w-8 dark:hidden"
      />
      <img
        src="/img/samostuduj_icon_white.svg"
        alt=""
        width="32"
        height="32"
        class="hidden h-8 w-8 dark:block"
      />
      <span class="text-lg font-bold tracking-tight">samostuduj</span>
    </a>

    <nav class="ml-auto hidden items-center gap-1 md:flex" aria-label="Hlavní">
      {
        nav.map((item) =>
          item.children ? (
            // Hover/focus-reveal group. The trigger is a real link when the
            // group has an index page (Obory → /obory) so it's clickable;
            // otherwise a plain button that just discloses the menu.
            <div class="group relative">
              {item.href ? (
                <a
                  href={item.href}
                  aria-current={isActive(item.href) ? "page" : undefined}
                  class:list={[
                    "flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium hover:text-accent",
                    (isGroupActive(item.children) || isActive(item.href)) && "text-accent",
                  ]}
                >
                  {item.label}
                  <span class="transition group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true">▾</span>
                </a>
              ) : (
                <button
                  type="button"
                  aria-haspopup="true"
                  class:list={[
                    "flex items-center gap-1 rounded-md px-3 py-2 text-sm font-medium hover:text-accent",
                    isGroupActive(item.children) && "text-accent",
                  ]}
                >
                  {item.label}
                  <span class="transition group-hover:rotate-180 group-focus-within:rotate-180" aria-hidden="true">▾</span>
                </button>
              )}
              {/* pt-2 is a transparent hover bridge so the menu doesn't close
                  in the gap between the trigger and the list. */}
              <div
                class="invisible absolute right-0 top-full translate-y-1 pt-2 opacity-0 transition duration-150 group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-within:visible group-focus-within:translate-y-0 group-focus-within:opacity-100"
              >
                <ul class="min-w-44 rounded-lg border border-border bg-surface p-1">
                  {item.children.map((c) => (
                    <li>
                      <a
                        href={c.href}
                        aria-current={isActive(c.href) ? "page" : undefined}
                        class:list={[
                          "block rounded-md px-3 py-2 text-sm hover:bg-bg hover:text-accent",
                          isActive(c.href) && "text-accent",
                        ]}
                      >
                        {c.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              aria-current={isActive(item.href!) ? "page" : undefined}
              class:list={[
                "rounded-md px-3 py-2 text-sm font-medium hover:text-accent",
                isActive(item.href!) && "text-accent",
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
      <button
        data-theme-toggle
        type="button"
        aria-label="Přepnout světlý/tmavý režim"
        title="Přepnout světlý/tmavý režim"
        class="ml-1 flex items-center rounded-md border border-border px-2 py-2 hover:border-accent hover:text-accent"
      >
        <span class="dark:hidden"><Icon name="moon" size={18} /></span>
        <span class="hidden dark:inline"><Icon name="sun" size={18} /></span>
      </button>
    </nav>

    <!-- Mobile: collapsible menu -->
    <details class="ml-auto md:hidden" data-mobile-menu>
      <summary
        class="flex cursor-pointer list-none items-center rounded-md border border-border px-3 py-2 text-sm"
        aria-label="Menu"
      >
        ☰
      </summary>
      <div
        class="absolute left-0 right-0 mt-3 border-y border-border bg-surface px-4 py-4"
      >
        <!-- Start here: the two primary ways in -->
        <div class="grid grid-cols-2 gap-2">
          <a
            href="/obory"
            aria-current={isActive("/obory") ? "page" : undefined}
            class:list={[
              "rounded-lg border px-3 py-3 text-center font-semibold hover:border-accent hover:text-accent",
              isActive("/obory") ? "border-accent text-accent" : "border-border",
            ]}
          >
            Obory
          </a>
          <a
            href="/plany"
            aria-current={isActive("/plany") ? "page" : undefined}
            class:list={[
              "rounded-lg border px-3 py-3 text-center font-semibold hover:border-accent hover:text-accent",
              isActive("/plany") ? "border-accent text-accent" : "border-border",
            ]}
          >
            Studijní plány
          </a>
        </div>

        <!-- Fields, collapsed by default -->
        <details class="group mt-3">
          <summary
            class="flex cursor-pointer list-none items-center justify-between rounded-md px-1 py-2 text-xs font-medium uppercase tracking-wide text-muted"
          >
            Obory podle zaměření
            <span class="transition group-open:rotate-180" aria-hidden="true">▾</span>
          </summary>
          <ul class="mt-1 grid grid-cols-2 gap-x-3">
            {oboryFields.map((c) => (
              <li>
                <a
                  href={c.href}
                  aria-current={isActive(c.href) ? "page" : undefined}
                  class:list={[
                    "block rounded-md px-1 py-2 text-sm hover:text-accent",
                    isActive(c.href) && "text-accent",
                  ]}
                >
                  {c.label}
                </a>
              </li>
            ))}
          </ul>
        </details>

        <!-- Secondary destinations -->
        <ul class="mt-3 space-y-1 border-t border-border pt-3">
          <li>
            <a
              href="/blog"
              aria-current={isActive("/blog") ? "page" : undefined}
              class:list={["block rounded-md px-1 py-2 font-medium hover:text-accent", isActive("/blog") && "text-accent"]}
            >
              Blog
            </a>
          </li>
          <li>
            <a
              href="/letaky"
              aria-current={isActive("/letaky") ? "page" : undefined}
              class:list={["block rounded-md px-1 py-2 font-medium hover:text-accent", isActive("/letaky") && "text-accent"]}
            >
              Letáky
            </a>
          </li>
        </ul>

        <!-- About the project -->
        <ul class="mt-3 grid grid-cols-2 gap-x-3 border-t border-border pt-3">
          {[
            { label: "O projektu", href: "/o-projektu" },
            { label: "Chci pomoct", href: "/chci-pomoct" },
            { label: "FAQ", href: "/faq" },
            { label: "Kontakt", href: "/kontakt" },
          ].map((c) => (
            <li>
              <a
                href={c.href}
                aria-current={isActive(c.href) ? "page" : undefined}
                class:list={[
                  "block rounded-md px-1 py-2 text-sm hover:text-accent",
                  isActive(c.href) ? "text-accent" : "text-muted",
                ]}
              >
                {c.label}
              </a>
            </li>
          ))}
        </ul>

        <!-- Appearance -->
        <div class="mt-3 flex items-center justify-between border-t border-border pt-3">
          <span class="px-1 text-sm text-muted">Vzhled</span>
          <button
            data-theme-toggle
            type="button"
            aria-label="Přepnout světlý/tmavý režim"
            class="flex items-center gap-2 rounded-md border border-border px-3 py-2 text-sm hover:border-accent hover:text-accent"
          >
            <span class="dark:hidden"><Icon name="moon" size={18} /></span>
            <span class="hidden dark:inline"><Icon name="sun" size={18} /></span>
            <span class="dark:hidden">Tmavý</span>
            <span class="hidden dark:inline">Světlý</span>
          </button>
        </div>
      </div>
    </details>
  </div>
</header>

<!-- Scrim behind the open mobile menu (progressive enhancement) -->
<div
  data-menu-scrim
  hidden
  class="fixed inset-0 z-40 bg-black/40 md:hidden"
  aria-hidden="true"
></div>

<script>
  // Theme toggle — persists choice. The head script has already resolved an
  // explicit .dark/.light class, so we can read it directly here.
  // Bound to every [data-theme-toggle] (desktop nav + mobile menu).
  const KEY = "samostuduj-theme";
  const root = document.documentElement;

  const toggleTheme = () => {
    const next = root.classList.contains("dark") ? "light" : "dark";
    root.classList.remove("dark", "light");
    root.classList.add(next);
    localStorage.setItem(KEY, next);
  };
  document
    .querySelectorAll("[data-theme-toggle]")
    .forEach((btn) => btn.addEventListener("click", toggleTheme));

  // Mobile menu scrim — dim the page while the menu is open; tap to close.
  const menu = document.querySelector(
    "[data-mobile-menu]",
  ) as HTMLDetailsElement | null;
  const scrim = document.querySelector("[data-menu-scrim]");
  if (menu && scrim) {
    menu.addEventListener("toggle", () => {
      if (menu.open) scrim.removeAttribute("hidden");
      else scrim.setAttribute("hidden", "");
    });
    scrim.addEventListener("click", () => menu.removeAttribute("open"));
  }
</script>

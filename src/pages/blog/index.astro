---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat("cs-CZ", { dateStyle: "long" });
---

<BaseLayout title="Blog" description="Články o samostudiu, svobodě učení a sebeřízeném vzdělávání.">
  <section class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Blog</h1>
    <p class="mt-3 text-muted">
      Úvahy o samostudiu, svobodě učení a sebeřízeném vzdělávání.
    </p>

    <ul class="mt-10 space-y-8">
      {
        posts.map((post) => (
          <li class="border-b border-border pb-8 last:border-0">
            <time class="text-xs text-muted" datetime={post.data.date.toISOString()}>
              {dateFmt.format(post.data.date)}
            </time>
            <h2 class="mt-1 text-xl font-semibold">
              <a href={`/blog/${post.id}`} class="hover:text-accent">
                {post.data.title}
              </a>
            </h2>
            {post.data.summary && (
              <p class="mt-2 text-muted">{post.data.summary}</p>
            )}
            <p class="mt-2 text-sm text-muted">{post.data.author}</p>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

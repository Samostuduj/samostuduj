---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/Icon.astro";
import StatusBadge from "../../components/StatusBadge.astro";

const entries = (await getCollection("obory")).sort(
  (a, b) => a.data.order - b.data.order
);

// Split by readiness: what you can study today vs. what's still coming.
const ready = entries.filter((e) => e.data.status !== "planovano");
const planned = entries.filter((e) => e.data.status === "planovano");
---

<BaseLayout title="Obory" description="Čím se jednotlivé obory zabývají — a kudy se do nich dát.">
  <section class="mx-auto max-w-5xl px-4 py-16 md:px-6">
    <h1 class="text-3xl font-bold tracking-tight md:text-4xl">Obory</h1>
    <p class="mt-3 max-w-2xl text-muted">
      Čím se jednotlivé obory zabývají — poctivě a bez příkras. Tam, kde už máme
      materiály, tě u oboru navedeme dál k úvodům a doporučeným zdrojům.
    </p>

    {
      ready.length > 0 && (
        <div class="mt-12">
          <h2 class="text-xl font-semibold">Můžeš studovat teď</h2>
          <div class="mt-5 grid gap-4 sm:grid-cols-2">
            {ready.map((entry) => (
              <a
                href={`/obory/${entry.id}`}
                class="group flex flex-col rounded-xl border border-border bg-surface p-6 transition-colors hover:border-accent focus-visible:border-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-bg"
              >
                <span class="flex h-11 w-11 items-center justify-center rounded-lg bg-accent/10 text-accent">
                  <Icon name={entry.data.icon as any} size={24} />
                </span>
                <h3 class="mt-4 text-lg font-semibold transition-colors group-hover:text-accent">
                  {entry.data.title}
                </h3>
                <p class="mt-1.5 text-sm leading-relaxed text-muted">
                  {entry.data.about ?? entry.data.summary}
                </p>
                <div class="mt-auto flex items-center justify-between pt-4">
                  <StatusBadge status={entry.data.status} />
                  <span
                    class="text-accent opacity-0 transition-opacity group-hover:opacity-100"
                    aria-hidden="true"
                  >
                    →
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      )
    }

    {
      planned.length > 0 && (
        <div class="mt-14">
          <h2 class="text-xl font-semibold">Připravujeme</h2>
          <ul class="mt-5 space-y-1">
            {planned.map((entry) => (
              <li>
                <a
                  href={`/obory/${entry.id}`}
                  class="group -mx-3 flex items-start gap-4 rounded-lg px-3 py-3 transition-colors hover:bg-surface focus-visible:bg-surface focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent"
                >
                  <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-border text-muted transition-colors group-hover:text-fg">
                    <Icon name={entry.data.icon as any} size={18} />
                  </span>
                  <span class="min-w-0">
                    <span class="block font-medium transition-colors group-hover:text-accent">
                      {entry.data.title}
                    </span>
                    <span class="mt-1 block text-sm leading-relaxed text-muted">
                      {entry.data.about ?? entry.data.summary}
                    </span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </section>
</BaseLayout>

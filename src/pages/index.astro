---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Icon from "../components/Icon.astro";
import TypeBadge from "../components/TypeBadge.astro";
import { getLiveAktuality, pickHero } from "../lib/aktuality";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const aktuality = pickHero(await getLiveAktuality());

const audience = [
  { icon: "graduation-cap", title: "Zklamaní studenti", text: "Školní systém tě zklamal? Vezmi vzdělávání do vlastních rukou — uč se to, co tě opravdu zajímá, vlastním tempem." },
  { icon: "clock", title: "Zaneprázdnění", text: "Rodiče i vytížení pracující. Přehledné materiály, aby bylo studium co nejjednodušší — bez zbytečného tlaku." },
  { icon: "sparkles", title: "Polyhistorové", text: "Od fyziky po filozofii. Nemusíš čekat na školní osnovy — poskládej si vlastní plán, přesně jak ti dává smysl." },
  { icon: "compass", title: "Nenašel jsem se", text: "To je v pořádku. Žádné škatulky — jen prostor učit se tak, jak ti to vyhovuje." },
] as const;

const dateFmt = new Intl.DateTimeFormat("cs-CZ", { dateStyle: "long" });
const dateShort = new Intl.DateTimeFormat("cs-CZ", { day: "numeric", month: "long" });
---

<BaseLayout>
  <!-- Hero + aktuálně panel -->
  <section class="mx-auto max-w-5xl px-4 pt-16 pb-12 md:px-6 md:pt-24">
    <div class="gap-10 md:grid md:grid-cols-[2fr_1fr] md:items-stretch">
      <div>
        <h1 class="max-w-3xl text-4xl font-bold leading-tight tracking-tight md:text-5xl">
          Učení není pro každého stejné.<br />
          <span class="text-accent">Uč se po svém.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg text-fg">
          Ze školy sis odnesl(a) spíš pachuť než motivaci? Možná to jen chce jiný
          přístup. <em>Samostuduj</em> je projekt pro lidi, kteří se chtějí vzdělávat
          stejně důkladně jako na vysoké škole — ale po svém.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-x-6 gap-y-3">
          <a
            href="/plany"
            class="rounded-lg bg-accent px-5 py-3 font-medium text-accent-contrast transition hover:opacity-90"
          >
            Prozkoumat studijní plány
          </a>
          <a
            href="/blog"
            class="font-medium text-muted transition hover:text-accent"
          >
            Číst blog →
          </a>
        </div>
      </div>

      <aside class="mt-10 flex flex-col rounded-2xl border border-border bg-surface p-6 md:mt-0">
        <div class="flex items-baseline justify-between gap-3">
          <h2 class="font-semibold">Aktuálně</h2>
          <a href="/aktuality" class="text-xs text-accent hover:underline">
            Vše →
          </a>
        </div>
        {
          aktuality.length > 0 ? (
            <ul class="mt-3 divide-y divide-border">
              {aktuality.map((entry) => {
                const Tag = entry.data.link ? "a" : "div";
                return (
                  <li>
                    <Tag
                      {...(entry.data.link ? { href: entry.data.link } : {})}
                      class:list={[
                        "group block py-3",
                        entry.data.link && "cursor-pointer",
                      ]}
                    >
                      <div class="flex items-center justify-between gap-2">
                        <TypeBadge type={entry.data.type} />
                        <time
                          class="shrink-0 text-xs text-muted"
                          datetime={entry.data.date.toISOString()}
                        >
                          {dateShort.format(entry.data.date)}
                        </time>
                      </div>
                      <p
                        class:list={[
                          "mt-1.5 text-sm font-medium leading-snug",
                          entry.data.link &&
                            "transition-colors group-hover:text-accent",
                        ]}
                      >
                        {entry.data.title}
                      </p>
                    </Tag>
                  </li>
                );
              })}
            </ul>
          ) : (
            <div class="mt-3 flex flex-1 flex-col items-center justify-center gap-2 py-6 text-center">
              <Icon name="megaphone" size={22} class="text-muted" />
              <p class="text-sm text-muted">Zatím tu nic nového. Brzy!</p>
            </div>
          )
        }
      </aside>
    </div>
  </section>

  <!-- Jak to funguje -->
  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6">
    <h2 class="text-2xl font-bold">Jak to funguje</h2>
    <p class="mt-4 max-w-2xl leading-relaxed text-muted">
      Vysokou školu nedělá budova ani diplom — dělá ji obsah: v jakém pořadí
      věci procházíš a z čeho se učíš. Obojí tu najdeš. Studijní plány tě
      provedou oborem od úvodu po magisterskou úroveň, z kvalitních veřejně
      dostupných zdrojů — zadarmo, vlastním tempem a bez žádných
      zbytečných závazků.
    </p>

    <dl class="mt-8 max-w-2xl border-y border-border">
      <div class="grid gap-1 border-t border-border py-4 first:border-t-0 sm:grid-cols-[9rem_1fr] sm:gap-6">
        <dt>
          <a href="/obory" class="font-semibold text-accent hover:underline">obory</a>
        </dt>
        <dd class="text-muted">
          Rozcestník oborem — kde začít a co číst dál, od úvodu po doporučené materiály.
        </dd>
      </div>
      <div class="grid gap-1 border-t border-border py-4 first:border-t-0 sm:grid-cols-[9rem_1fr] sm:gap-6">
        <dt>
          <a href="/plany" class="font-semibold text-accent hover:underline">studijní plány</a>
        </dt>
        <dd class="text-muted">
          Osnova, která tě provede oborem krok za krokem. Jako univerzitní sylabus, ale svobodný a zdarma.
        </dd>
      </div>
      <div class="grid gap-1 border-t border-border py-4 first:border-t-0 sm:grid-cols-[9rem_1fr] sm:gap-6">
        <dt>
          <a href="/manifest" class="font-semibold text-accent hover:underline">manifest</a>
        </dt>
        <dd class="text-muted">
          Proč to děláme a na čem projekt stojí — principy, ke kterým se hlásíme.
        </dd>
      </div>
    </dl>
  </section>

  <!-- Pro koho -->
  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6">
    <h2 class="text-2xl font-bold">Pro koho samostudium je?</h2>
    <div class="mt-10 grid gap-x-12 gap-y-12 sm:grid-cols-2">
      {
        audience.map((a) => (
          <div class="grid grid-cols-[auto_1fr] items-start gap-x-5">
            <span class="row-span-2 inline-flex h-14 w-14 items-center justify-center self-center rounded-xl bg-black/25">
              <Icon name={a.icon} size={30} class="text-accent" />
            </span>
            <h3 class="font-semibold">{a.title}</h3>
            <p class="col-start-2 mt-1 text-sm leading-relaxed text-muted">{a.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Nejnovější z blogu -->
  <section class="mx-auto max-w-5xl px-4 py-12 md:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-2xl font-bold">Nejnovější z blogu</h2>
      <a href="/blog" class="text-sm text-accent hover:underline">Všechny články →</a>
    </div>
    <ul class="mt-6 grid gap-4 md:grid-cols-3">
      {
        posts.map((post) => (
          <li class="rounded-xl border border-border bg-surface p-5 transition hover:border-accent">
            <a href={`/blog/${post.id}`} class="block">
              <time class="text-xs text-muted" datetime={post.data.date.toISOString()}>
                {dateFmt.format(post.data.date)}
              </time>
              <h3 class="mt-1 font-semibold leading-snug">{post.data.title}</h3>
              {post.data.summary && (
                <p class="mt-2 text-sm text-muted">{post.data.summary}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <!-- Kde začít -->
  <section class="mx-auto max-w-5xl px-4 pb-24 pt-8 md:px-6">
    <div class="rounded-2xl border border-border bg-surface p-8 md:flex md:items-center md:justify-between md:gap-8 md:p-10">
      <div>
        <h2 class="text-2xl font-bold">Kde začít?</h2>
        <p class="mt-2 max-w-xl text-muted">
          Vyber si studijní plán a projdi obor krok za krokem — vlastním tempem a zadarmo.
        </p>
      </div>
      <a
        href="/plany"
        class="mt-6 inline-block shrink-0 rounded-lg bg-accent px-5 py-3 font-medium text-accent-contrast transition hover:opacity-90 md:mt-0"
      >
        Prozkoumat studijní plány
      </a>
    </div>
  </section>
</BaseLayout>
